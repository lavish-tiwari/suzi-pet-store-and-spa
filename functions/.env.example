# Suzi Pet Store and Spa - Cloud Functions Environment Variables Template
# Copy this file to .env inside the functions directory and update with SMTP and owner details.

# SMTP Email Server Configuration (e.g. Gmail SMTP, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_or_email@gmail.com
SMTP_PASS=your_smtp_app_password

# Outgoing notifications sender email
SENDER_EMAIL=noreply@suzipetstore.com

# OWNER NOTIFICATION EMAIL
# [PLACEHOLDER - client to provide before launch]
# Replace this value with the business owner's real email address before deploying.
OWNER_EMAIL=owner@suzipetstore.com
